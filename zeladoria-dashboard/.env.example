# ==============================================
# Zeladoria Dashboard — Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e ajuste os valores

# ── MODO DE API ────────────────────────────────
# true  → usa dados mock locais (desenvolvimento sem backend)
# false → usa a API real (zeladoria-api no Easepanel)
VITE_USE_MOCK_API=false

# ── URL DA API (zeladoria-api) ─────────────────
# Local (dev):
# VITE_API_BASE_URL=http://localhost:3001
#
# Easepanel (produção) — substitua pelo domínio do seu serviço:
VITE_API_BASE_URL=https://zeladoria-api.seudominio.com.br

# ── Storage de mídias (MinIO/S3) ──────────────
VITE_STORAGE_URL=http://localhost:9000/zeladoria
