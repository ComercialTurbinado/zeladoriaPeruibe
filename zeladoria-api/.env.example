# ======================================
# Zeladoria API — Variáveis de Ambiente
# ======================================
# Copie para .env e ajuste os valores

# MongoDB (Easepanel)
MONGODB_URI=mongodb://zeladoriaPeruibe:zeladoriaPeruibe!23@n8n-srcleads_zeladoria_peruibe:27017/zeladoria?tls=false

# JWT
JWT_SECRET=troque-por-um-secret-forte-aqui
JWT_EXPIRES_IN=24h

# Servidor
PORT=3001
NODE_ENV=production

# CORS — domínio do dashboard (frontend)
CORS_ORIGIN=http://localhost:3000

# n8n Webhook — disparado quando status é atualizado (notifica cidadão via WhatsApp)
N8N_WEBHOOK_STATUS_URL=http://n8n-srcleads_zeladoria_peruibe:5678/webhook/status-atualizado
N8N_WEBHOOK_TOKEN=seu-token-n8n-aqui

# Evolution API (usado pelo n8n — apenas referência)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE=zeladoria
